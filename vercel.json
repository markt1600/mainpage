{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/dashboard.js": {
      "maxDuration": 60
    },
    "api/sports.js": {
      "maxDuration": 60
    },
    "api/admin.js": {
      "maxDuration": 15
    },
    "api/notify.js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/admin", "destination": "/admin.html" }
  ],
  "crons": [
    {
      "path": "/api/dashboard",
      "schedule": "15 23 * * *"
    },
    {
      "path": "/api/sports",
      "schedule": "0 22 * * *"
    },
    {
      "path": "/api/notify",
      "schedule": "20 23 * * *"
    }
  ]
}
