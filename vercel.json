{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/dashboard.js": {
      "maxDuration": 60
    },
    "api/sports.js": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/dashboard",
      "schedule": "15 23 * * *"
    },
    {
      "path": "/api/sports",
      "schedule": "0 22 * * *"
    }
  ]
}
